# ===============================
# AIShields canonical environment variables
# (The services also accept legacy unprefixed vars for backward compatibility.)
# ===============================
AISHIELDS_POLICY_API_SECRET=change-me-policy
AISHIELDS_DETECTION_API_SECRET=change-me-detection
AISHIELDS_CONTROL_PLANE_URL=http://control-plane:8000
AISHIELDS_CA_DIR=/etc/aishields/certs
AISHIELDS_FIPS_MODE=false

# Core auth secrets
AISHIELDS_API_SECRET=change-me
AISHIELDS_JWT_SECRET=change-me-jwt
POLICY_API_SECRET=change-me-policy
POLICY_API_KEY=change-me-policy
DETECTION_API_SECRET=change-me-detection
IDENTITY_API_SECRET=change-me-identity
SIEM_API_SECRET=change-me-siem
COMPLIANCE_API_SECRET=change-me-compliance
PROXY_AGENT_API_SECRET=change-me-proxy
TELEMETRY_API_KEY=change-me-siem

# Database
DATABASE_URL=postgresql://cyberarmor:cyberarmor@postgres:5432/cyberarmor

# Service URLs
CONTROL_PLANE_URL=http://control-plane:8000
POLICY_SERVICE_URL=http://policy:8001
DETECTION_SERVICE_URL=http://detection:8002
AISR_RUNTIME_URL=http://runtime:8000
PROXY_AGENT_URL=http://proxy-agent:8010
TELEMETRY_ENDPOINT=http://siem-connector:8005/ingest
COMPLIANCE_URL=http://compliance:8006

# Tenant/runtime defaults
TENANT_ID=default
DEFAULT_PROXY_RUNTIME_MODE=mitm
# JSON object map: {"tenant-a":"envoy","tenant-b":"mitm"}
TENANT_PROXY_MODES={}
TENANT_MODE_CACHE_TTL_SECONDS=60

# Proxy behavior
PROXY_MODE=transparent
FAIL_OPEN=true
LOG_LEVEL=INFO
